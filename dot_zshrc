cc-glm() {
  [[ ! -v $ANTHROPIC_AUTH_TOKEN ]] && echo "Variable not set" 
  ANTHROPIC_AUTH_TOKEN=${ANTHROPIC_AUTH_TOKEN} \
  ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic" \
  ANTHROPIC_DEFAULT_OPUS_MODEL="glm-4.6" \
  ANTHROPIC_DEFAULT_SONNET_MODEL="glm-4.6" \
  ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.6" \
  API_TIMEOUT_MS="300000" \
  claude --dangerously-skip-permissions --model glm-4.6 "$@"
}

wt() {
  local name="$1"
  local base=$(git rev-parse --show-toplevel)
  local parent=$(dirname "$base")
  local repo=$(basename "$base" | sed 's/-[^-]*$//')  # strip existing suffix
  
  git worktree add "$parent/${repo}-${name}" -b "$name" 2>/dev/null || \
  git worktree add "$parent/${repo}-${name}" "$name"  # if branch exists
  
  cd "$parent/${repo}-${name}"
  mise trust 
}

# List and pick worktree with fzf
wtp() {
  local selected=$(git worktree list | fzf --height 40% --reverse | awk '{print $1}')
  [[ -n "$selected" ]] && cd "$selected"
}

wtr() {
  local sel=$(git worktree list | tail -n +2 | fzf --height 40% --reverse)
  [[ -z "$sel" ]] && return
  local p=$(echo "$sel" | awk '{print $1}')
  git worktree remove $p 
  echo "Deleted $p"
}

# List all worktrees
wtl() {
  git worktree list
}



