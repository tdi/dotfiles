}


wt() {
  local name="$1"
  local base=$(git rev-parse --show-toplevel)
  local parent=$(dirname "$base")
  local repo=$(basename "$base" | sed 's/-[^-]*$//')
  local target="$parent/${repo}-${name}"
  
  git worktree add "$target" -b "$name" 2>/dev/null || \
  git worktree add "$target" "$name"
  
  # Copy all env files
  for f in "$base"/.env*; do
    [[ -f "$f" ]] && cp "$f" "$target/"
  done
  
  cd "$target"
  mise trust
}


# List and pick worktree with fzf
wtp() {
  local selected=$(git worktree list | fzf --height 40% --reverse | awk '{print $1}')
  [[ -n "$selected" ]] && cd "$selected"
}

wtr() {
  local sel=$(git worktree list | tail -n +2 | fzf --height 40% --reverse)
  [[ -z "$sel" ]] && return
  local p=$(echo "$sel" | awk '{print $1}')
  git worktree remove -f $p 
  echo "Deleted $p"
}

# List all worktrees
wtl() {
  git worktree list
}



